{
  "meta": {
    "title": "고등수학 한글 수식 입력 매핑 사전",
    "version": "1.0",
    "description": "한글 프로그램 수식입력기용 코드 매핑. Claude Code에서 수학 풀이를 한글 수식 코드로 자동 변환할 때 사용."
  },

  "global_rules": {
    "font_mode": {
      "default": "italic",
      "roman": "rm 입력 시 로마체로 전환. 도형의 점(A,B,C 등), 확률 P, 기댓값 E, 분산 V, 정규분포 N, 순열 P, 조합 C, 중복조합 H 등은 반드시 rm 사용",
      "italic_restore": "it 입력 시 다시 이탤릭체로 전환",
      "example": "rmP it left(A` right) → P는 로마체, 괄호 안 A 뒤 백틱"
    },
    "spacing": {
      "backtick": "` 는 작은 띄어쓰기 (강제 공백)",
      "tilde": "~ 는 큰 띄어쓰기. 백틱 4개와 동일",
      "keyword_spacing": "le, ge, ne 등 키워드 앞뒤에 다른 문자가 오면 공백 필요. 예: x ge 3"
    },
    "brackets": {
      "parenthesis": "left( ... right) 로 입력. 함수명과 left 사이 띄어쓰기 필요. 예: f left(x right)",
      "curly_brace": "left{ ... right} 로 입력. 코드상 중괄호 {}와 구분",
      "square_bracket": "left[` ... `right] 로 입력",
      "absolute_value": "left|` ... `right| 로 입력"
    },
    "subscript_at_start": "수식 맨 앞에 아래첨자가 올 때 빈 중괄호 선행. 예: {}_{n}{rmC it}_{r}",
    "roman_uppercase_with_bracket": "로마체 대문자 알파벳으로 수식이 끝나거나 괄호가 들어가는 경우 백틱 입력. 예: rmP it left(A` right)",
    "line_break": "# 은 수식 내 줄바꿈. 구간별 정의 함수에서만 사용하고 나머지는 별도 수식으로 분리",
    "korean_in_formula": "수식 내 한글이 필요한 경우 수식창과 한글창을 분리하여 입력"
  },

